<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.brenden.cloud.mapper.UserMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.brenden.cloud.entity.UserDO">
        <result column="id" property="id" />
        <result column="is_delete" property="isDelete" />
        <result column="create_by" property="createBy" />
        <result column="update_by" property="updateBy" />
        <result column="gmt_create" property="gmtCreate" />
        <result column="gmt_modified" property="gmtModified" />
        <result column="username" property="username" />
        <result column="password" property="password" />
        <result column="email" property="email" />
        <result column="mobile" property="mobile" />
        <result column="status" property="status" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id,
        is_delete,
        create_by,
        update_by,
        gmt_create,
        gmt_modified,
        username, password, email, mobile, status
    </sql>


    <resultMap id="usernameRoleMap"  type="com.brenden.cloud.dto.UserRoleDTO">
        <id property="userId" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="mobile" column="mobile"/>
        <result property="email" column="email"/>
        <result property="status" column="status"/>
        <collection property="roles" ofType="string">
            <result column="role_code"/>
        </collection>
    </resultMap>

    <select id="getByUsername" resultMap="usernameRoleMap">
        SELECT
            u.id,
            u.username,
            u.`password`,
            u.mobile,
            u.email,
            u.`status`,
            r.`code` as role_code
        FROM
            sys_user u
        LEFT JOIN sys_user_role ur ON u.id = ur.user_id
            AND ur.is_delete = 0
        LEFT JOIN sys_role r ON ur.role_id = r.id
            AND ur.is_delete = 0
        WHERE u.username = #{username} and u.is_delete = 0
    </select>

    <select id="getUserById" resultMap="usernameRoleMap">
        SELECT
        u.id,
        u.username,
        u.`password`,
        u.mobile,
        u.email,
        u.`status`,
        r.`code` as role_code
        FROM
        sys_user u
        LEFT JOIN sys_user_role ur ON u.id = ur.user_id
        AND ur.is_delete = 0
        LEFT JOIN sys_role r ON ur.role_id = r.id
        AND ur.is_delete = 0
        WHERE u.id = #{userId} and u.is_delete = 0
    </select>
</mapper>
